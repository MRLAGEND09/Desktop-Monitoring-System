# ── Secrets ──────────────────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
DEVICE_TOKEN_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=rdm_db
POSTGRES_USER=rdm_user
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://rdm_user:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/rdm_db

# ── Services ──────────────────────────────────────────────────────────────────
SIGNALING_PORT=4000
BACKEND_PORT=8000
FRONTEND_PORT=5173
VITE_API_URL=/api
VITE_SIGNALING_URL=ws://localhost:4000/ws
VITE_STUN_URL=stun:localhost:3478

# ── TURN Server ───────────────────────────────────────────────────────────────
TURN_DOMAIN=turn.yourdomain.com
TURN_SECRET=REPLACE_WITH_TURN_SECRET
TURN_PORT=3478

# ── WebSocket tuning ──────────────────────────────────────────────────────────
WS_MAX_CONNS_PER_IP=10
WS_PING_INTERVAL_MS=30000

# ── TLS ───────────────────────────────────────────────────────────────────────
DOMAIN=yourdomain.com
CERTBOT_EMAIL=admin@yourdomain.com

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["https://yourdomain.com","http://localhost:5173"]

# ── Metrics ───────────────────────────────────────────────────────────────────
# Optional: bearer token for external Prometheus scraper to access /metrics
# Leave empty to allow scraping only from internal Docker network (127.0.0.1 / 10.x / 172.x)
METRICS_TOKEN=

# ── Grafana ───────────────────────────────────────────────────────────────────
# Password for the Grafana 'admin' account (accessible at /grafana/)
GRAFANA_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
